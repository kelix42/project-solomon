# ──────────────────────────────────────────────────────────────────────
# Solomon — environment template. Copy to .env and fill in real values.
# install.sh reuses anything already set in ~/.hermes/.env (Hermes config).
# ──────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────

# Pinecone (vector memory)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=solomon
PINECONE_REGION=us-east-1

# OpenAI (embeddings — used by Sleep-Cycle Job 11)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=3072

# Telegram (owner interface — handled by Hermes gateway adapter)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Backup (auto-generated by install.sh on first run; do not edit by hand)
SOLOMON_BACKUP_KEY_WRAPPED=
BACKUP_DEST_LOCAL=$HOME/Backups/solomon

# ── OPTIONAL INTEGRATIONS ─────────────────────────────────────────────

# Plaud (voice transcripts via IMAP) — required if `plaud-ingest` worker enabled
PLAUD_IMAP_HOST=imap.gmail.com
PLAUD_IMAP_USER=
PLAUD_IMAP_PASS=
PLAUD_SENDER=no-reply@plaud.ai

# Google Workspace (Gmail + Calendar + Drive via MCP)
GOOGLE_MCP_SERVER_URL=

# n8n / make.com webhook orchestrator
WORKFLOW_WEBHOOK_URL=

# Whoop (owner-state biometrics)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# ── MODEL OVERRIDES (per-stage; default to Claude family) ─────────────
# SOLOMON_MODEL_SALIENCE=claude-haiku-4-5-20251001
# SOLOMON_MODEL_CLASSIFICATION=claude-sonnet-4-6
# SOLOMON_MODEL_SYSTEM1=claude-sonnet-4-6
# SOLOMON_MODEL_SYSTEM2=claude-opus-4-7
# SOLOMON_MODEL_AUDIT=claude-opus-4-7
# SOLOMON_MODEL_INTERVIEW=claude-sonnet-4-6
# SOLOMON_MODEL_VOCAB=claude-sonnet-4-6
# SOLOMON_MODEL_INGEST=claude-sonnet-4-6
# SOLOMON_MODEL_FORGET=claude-opus-4-7

# OpenRouter fallback (used if direct Anthropic/OpenAI fails per §2.4.7)
# OPENROUTER_API_KEY=
